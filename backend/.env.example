# App
APP_NAME=Swell Store
DEBUG=false

# MongoDB
MONGODB_URL=mongodb://swelladmin:swellpassword@mongo:27017/swelldb?authSource=admin
MONGODB_DB_NAME=swelldb

# JWT — gere com: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — origem do frontend
ALLOWED_ORIGINS=["http://localhost","http://localhost:80"]

# Upload
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE_MB=5
